{
    "name": "chocofamilyme/laravel-tarantool",
    "description": "A Tarantool based Eloquent ORM and Query builder for Laravel",
    "type": "library",
    "keywords": [
        "db",
        "tarantool",
        "laravel",
        "eloquent-tarantool",
        "eloquent",
        "orm"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/container": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/events": "^11.0 || ^12.0 || ^13.0",
        "rybakit/msgpack": "^0.7 || ^0.9",
        "tarantool/client": "^0.9.0 || ^0.10.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpunit/phpunit": "^11.5 || ^12.0 || ^13.0"
    },
    "license": [
        "BSD-3-Clause"
    ],
    "homepage": "https://github.com/chocofamilyme/laravel-tarantool",
    "authors": [
        {
            "name": "IT Rahmet App",
            "homepage": "https://rahmetapp.kz/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Chocofamily\\Tarantool\\": "src/Tarantool/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chocofamily\\Tarantool\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chocofamily\\Tarantool\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": [
            "@test:unit"
        ],
        "test:style": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
        "test:unit": "@php vendor/bin/phpunit"
    }
}
